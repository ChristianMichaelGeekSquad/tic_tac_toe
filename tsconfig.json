{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "types": ["jest"],
    "typeRoots": ["./node_modules/@types"],
    "jsx": "react-native",
    "baseUrl": ".",
     "paths": {
      "*": [
        "src/*",
      ],
      "assets/*": [
        "src/assets/*"
      ],
      "components/*": [
        "src/components/*"
      ],
      "navigation/*": [
        "src/navigation/*"
      ],
      "features/*": [
        "src/features/*"
      ],
      "tailwind/*": [
        "tailwind/*"
      ],
      "tailwindConfig": [
        "./tailwind.config.js"
      ],
      "general_utils/*": [
        "general_utils/*"
      ],
    }
  },
  "include": [
    "**/*.ts", 
    "**/*.tsx", 
    "**/*.svg", 
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "**/node_modules", 
    "**/Pods"
  ]
}
